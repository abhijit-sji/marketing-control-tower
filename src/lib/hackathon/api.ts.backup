// ================================================
// HACKATHON MODULE - API Service Functions
// ================================================

import { supabase } from "@/integrations/supabase/client";
import type {
  Employee,
  HackathonEvent,
  HackathonParticipant,
  HackathonTeam,
  HackathonTeamMember,
  HackathonSubmission,
  HackathonJudge,
  HackathonScore,
  CreateEventForm,
  ParticipantRegistrationForm,
  CreateTeamForm,
  SubmissionForm,
  JudgeScoreForm,
  EmployeeSyncResponse,
  HackathonInviteResponse,
} from "@/types/hackathon";

// ================================================
// Employee Management
// ================================================

export async function syncEmployees(): Promise<EmployeeSyncResponse> {
  const { data: { session } } = await supabase.auth.getSession();

  if (!session) {
    throw new Error('No active session');
  }

  const response = await fetch(
    `${import.meta.env.VITE_SUPABASE_URL}/functions/v1/employee-sync`,
    {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${session.access_token}`,
        'Content-Type': 'application/json',
      },
    }
  );

  if (!response.ok) {
    const error = await response.json();
    throw new Error(error.error || 'Failed to sync employees');
  }

  return response.json();
}

export async function getEmployees() {
  const { data, error } = await supabase
    .from('employees')
    .select('*')
    .eq('is_active', true)
    .order('last_name', { ascending: true });

  if (error) throw error;
  return data as Employee[];
}

export async function getEmployeeById(id: string) {
  const { data, error } = await supabase
    .from('employees')
    .select('*')
    .eq('id', id)
    .single();

  if (error) throw error;
  return data as Employee;
}

// ================================================
// Hackathon Events
// ================================================

export async function createHackathonEvent(form: CreateEventForm): Promise<HackathonEvent> {
  const { data: { user } } = await supabase.auth.getUser();

  if (!user) {
    throw new Error('User not authenticated');
  }

  const { data, error } = await supabase
    .from('hackathon_events')
    .insert({
      ...form,
      created_by: user.id,
      status: 'draft',
    })
    .select()
    .single();

  if (error) throw error;
  return data as HackathonEvent;
}

export async function updateHackathonEvent(id: string, updates: Partial<HackathonEvent>) {
  const { data, error } = await supabase
    .from('hackathon_events')
    .update(updates)
    .eq('id', id)
    .select()
    .single();

  if (error) throw error;
  return data as HackathonEvent;
}

export async function getHackathonEvents() {
  const { data, error } = await supabase
    .from('hackathon_events')
    .select('*')
    .order('start_date', { ascending: false });

  if (error) throw error;
  return data as HackathonEvent[];
}

export async function getHackathonEventById(id: string) {
  const { data, error } = await supabase
    .from('hackathon_events')
    .select('*')
    .eq('id', id)
    .single();

  if (error) throw error;
  return data as HackathonEvent;
}

export async function getOpenHackathonEvents() {
  const { data, error } = await supabase
    .from('hackathon_events')
    .select('*')
    .eq('status', 'open')
    .order('start_date', { ascending: true });

  if (error) throw error;
  return data as HackathonEvent[];
}

// ================================================
// Invitations
// ================================================

export async function sendHackathonInvites(
  eventId: string,
  employeeIds: string[]
): Promise<HackathonInviteResponse> {
  const { data: { session } } = await supabase.auth.getSession();

  if (!session) {
    throw new Error('No active session');
  }

  const response = await fetch(
    `${import.meta.env.VITE_SUPABASE_URL}/functions/v1/hackathon-invite`,
    {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${session.access_token}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ eventId, employeeIds }),
    }
  );

  if (!response.ok) {
    const error = await response.json();
    throw new Error(error.error || 'Failed to send invitations');
  }

  return response.json();
}

// ================================================
// Participants
// ================================================

export async function registerForHackathon(
  eventId: string,
  registration: ParticipantRegistrationForm
) {
  const { data: { user } } = await supabase.auth.getUser();

  if (!user) {
    throw new Error('User not authenticated');
  }

  // Get employee mapping
  const { data: mapping } = await supabase
    .from('employee_user_mapping')
    .select('employee_id')
    .eq('user_id', user.id)
    .single();

  if (!mapping) {
    throw new Error('Employee mapping not found');
  }

  const { data, error } = await supabase
    .from('hackathon_participants')
    .upsert({
      event_id: eventId,
      employee_id: mapping.employee_id,
      user_id: user.id,
      ...registration,
      status: 'registered',
    }, {
      onConflict: 'event_id,employee_id'
    })
    .select()
    .single();

  if (error) throw error;
  return data as HackathonParticipant;
}

export async function getParticipantsByEvent(eventId: string) {
  const { data, error } = await supabase
    .from('hackathon_participants')
    .select(`
      *,
      employee:employees(*)
    `)
    .eq('event_id', eventId);

  if (error) throw error;
  return data as HackathonParticipant[];
}

export async function getMyParticipation(eventId: string) {
  const { data: { user } } = await supabase.auth.getUser();

  if (!user) {
    throw new Error('User not authenticated');
  }

  const { data, error } = await supabase
    .from('hackathon_participants')
    .select('*')
    .eq('event_id', eventId)
    .eq('user_id', user.id)
    .single();

  if (error && error.code !== 'PGRST116') throw error;
  return data as HackathonParticipant | null;
}

// ================================================
// Teams
// ================================================

export async function createTeam(eventId: string, form: CreateTeamForm) {
  const { data: { user } } = await supabase.auth.getUser();

  if (!user) {
    throw new Error('User not authenticated');
  }

  const { data, error } = await supabase
    .from('hackathon_teams')
    .insert({
      event_id: eventId,
      team_lead_id: user.id,
      ...form,
      status: 'forming',
    })
    .select()
    .single();

  if (error) throw error;
  return data as HackathonTeam;
}

export async function getTeamsByEvent(eventId: string) {
  const { data, error } = await supabase
    .from('hackathon_teams')
    .select(`
      *,
      members:hackathon_team_members(
        *,
        participant:hackathon_participants(
          *,
          employee:employees(*)
        )
      )
    `)
    .eq('event_id', eventId);

  if (error) throw error;
  return data as HackathonTeam[];
}

export async function getMyTeam(eventId: string) {
  const { data: { user } } = await supabase.auth.getUser();

  if (!user) {
    throw new Error('User not authenticated');
  }

  // First check if user is a team lead
  const { data: leadTeam } = await supabase
    .from('hackathon_teams')
    .select(`
      *,
      members:hackathon_team_members(
        *,
        participant:hackathon_participants(
          *,
          employee:employees(*)
        )
      )
    `)
    .eq('event_id', eventId)
    .eq('team_lead_id', user.id)
    .single();

  if (leadTeam) return leadTeam as HackathonTeam;

  // Check if user is a team member
  const { data: participation } = await supabase
    .from('hackathon_participants')
    .select('id')
    .eq('event_id', eventId)
    .eq('user_id', user.id)
    .single();

  if (!participation) return null;

  const { data: membership } = await supabase
    .from('hackathon_team_members')
    .select('team_id')
    .eq('participant_id', participation.id)
    .single();

  if (!membership) return null;

  const { data: team } = await supabase
    .from('hackathon_teams')
    .select(`
      *,
      members:hackathon_team_members(
        *,
        participant:hackathon_participants(
          *,
          employee:employees(*)
        )
      )
    `)
    .eq('id', membership.team_id)
    .single();

  return team as HackathonTeam;
}

export async function addTeamMember(teamId: string, participantId: string, role?: string) {
  const { data, error } = await supabase
    .from('hackathon_team_members')
    .insert({
      team_id: teamId,
      participant_id: participantId,
      role,
    })
    .select()
    .single();

  if (error) throw error;
  return data as HackathonTeamMember;
}

export async function removeTeamMember(memberId: string) {
  const { error } = await supabase
    .from('hackathon_team_members')
    .delete()
    .eq('id', memberId);

  if (error) throw error;
}

// ================================================
// Submissions
// ================================================

export async function createOrUpdateSubmission(
  teamId: string,
  eventId: string,
  form: SubmissionForm
) {
  const { data, error } = await supabase
    .from('hackathon_submissions')
    .upsert({
      event_id: eventId,
      team_id: teamId,
      ...form,
      status: 'draft',
    }, {
      onConflict: 'event_id,team_id'
    })
    .select()
    .single();

  if (error) throw error;
  return data as HackathonSubmission;
}

export async function submitSubmission(submissionId: string) {
  const { data, error } = await supabase
    .from('hackathon_submissions')
    .update({
      status: 'submitted',
      submitted_at: new Date().toISOString(),
    })
    .eq('id', submissionId)
    .select()
    .single();

  if (error) throw error;
  return data as HackathonSubmission;
}

export async function getSubmissionsByEvent(eventId: string) {
  const { data, error } = await supabase
    .from('hackathon_submissions')
    .select(`
      *,
      team:hackathon_teams(*),
      scores:hackathon_scores(*)
    `)
    .eq('event_id', eventId)
    .eq('status', 'submitted');

  if (error) throw error;
  return data as HackathonSubmission[];
}

export async function getMySubmission(teamId: string) {
  const { data, error } = await supabase
    .from('hackathon_submissions')
    .select('*')
    .eq('team_id', teamId)
    .single();

  if (error && error.code !== 'PGRST116') throw error;
  return data as HackathonSubmission | null;
}

// ================================================
// Judges
// ================================================

export async function addJudge(eventId: string, userId: string, name: string, title?: string, domains?: string[]) {
  const { data, error } = await supabase
    .from('hackathon_judges')
    .insert({
      event_id: eventId,
      user_id: userId,
      judge_name: name,
      judge_title: title,
      expertise_domains: domains || [],
    })
    .select()
    .single();

  if (error) throw error;
  return data as HackathonJudge;
}

export async function getJudgesByEvent(eventId: string) {
  const { data, error } = await supabase
    .from('hackathon_judges')
    .select('*')
    .eq('event_id', eventId);

  if (error) throw error;
  return data as HackathonJudge[];
}

export async function isJudge(eventId: string) {
  const { data: { user } } = await supabase.auth.getUser();

  if (!user) return false;

  const { data } = await supabase
    .from('hackathon_judges')
    .select('id')
    .eq('event_id', eventId)
    .eq('user_id', user.id)
    .single();

  return !!data;
}

// ================================================
// Scoring
// ================================================

export async function submitScore(
  submissionId: string,
  judgeId: string,
  form: JudgeScoreForm
) {
  const { data, error } = await supabase
    .from('hackathon_scores')
    .upsert({
      submission_id: submissionId,
      judge_id: judgeId,
      ...form,
    }, {
      onConflict: 'submission_id,judge_id'
    })
    .select()
    .single();

  if (error) throw error;
  return data as HackathonScore;
}

export async function getScoresBySubmission(submissionId: string) {
  const { data, error } = await supabase
    .from('hackathon_scores')
    .select(`
      *,
      judge:hackathon_judges(*)
    `)
    .eq('submission_id', submissionId);

  if (error) throw error;
  return data as HackathonScore[];
}

export async function getMyScores(eventId: string) {
  const { data: { user } } = await supabase.auth.getUser();

  if (!user) {
    throw new Error('User not authenticated');
  }

  // Get judge record
  const { data: judge } = await supabase
    .from('hackathon_judges')
    .select('id')
    .eq('event_id', eventId)
    .eq('user_id', user.id)
    .single();

  if (!judge) return [];

  const { data, error } = await supabase
    .from('hackathon_scores')
    .select(`
      *,
      submission:hackathon_submissions(
        *,
        team:hackathon_teams(*)
      )
    `)
    .eq('judge_id', judge.id);

  if (error) throw error;
  return data as HackathonScore[];
}
